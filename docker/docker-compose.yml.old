services:
  slskd:
    image: slskd/slskd
    ports:
      - "5030:5030"
    volumes:
      - /mnt/nvme/musicserver/config/slskd/slskd.yml:/app/slskd.yml
      - /mnt/nvme/musicserver/downloads/incomplete:/downloads/incomplete
      - /mnt/nvme/musicserver/downloads:/downloads
    tmpfs:
      - /app
    restart: unless-stopped
  lidarr:
    image: linuxserver/lidarr:develop
    network_mode: host
    ports:
      - "8686:8686"
    volumes:
      - /media/beryl/nvme/musicserver/config/lidarr:/config
      - /mnt/data/Music:/music
      - /mnt/nvme/musicserver/downloads:/downloads
    restart: unless-stopped
    extra_hosts:
      - "host.docker.internal:host-gateway"
  navidrome:
      image: deluan/navidrome
      ports:
        - "4533:4533"
      volumes:
        - /mnt/data/Music:/music
        - /media/beryl/nvme/musicserver/config/navidrome:/data
      restart: unless-stopped

